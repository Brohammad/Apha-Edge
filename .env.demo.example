# AlphaEdge public demo — copy to .env.demo and adjust for your host.
# Used by: docker compose -f infrastructure/docker-compose.demo.yml

APP_ENV=development
APP_DEBUG=false

# Generate unique values before a public deploy:
APP_SECRET_KEY=demo-app-secret-change-me
JWT_SECRET_KEY=demo-jwt-secret-change-me

DATABASE_URL=postgresql+asyncpg://alphaedge:alphaedge@postgres:5432/alphaedge
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Demo-friendly defaults (no external API keys required)
LLM_PROVIDER=mock
RESEARCH_PROVIDER=mock
QUOTE_PROVIDER=auto
RATE_LIMIT_ENABLED=false
LIVE_TRADING_ENABLED=false
CPP_ENGINE=auto

# Same-origin via nginx gateway — add your public URL if fronting separately
CORS_ORIGINS=["http://localhost:8080"]

RUN_DEMO_SEED=true
