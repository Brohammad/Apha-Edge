{
  "dashboard": {
    "title": "AlphaEdge Business Metrics",
    "uid": "alphaedge-business",
    "panels": [
      {
        "title": "Orders submitted",
        "type": "stat",
        "targets": [{ "expr": "sum(increase(alphaedge_orders_submitted_total[24h]))" }]
      },
      {
        "title": "Active deployments",
        "type": "gauge",
        "targets": [{ "expr": "alphaedge_active_deployments" }]
      },
      {
        "title": "Insight requests",
        "type": "graph",
        "targets": [{ "expr": "rate(alphaedge_insight_requests_total[1h])" }]
      }
    ]
  }
}
