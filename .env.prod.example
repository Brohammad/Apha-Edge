# Production public demo at https://alphaedge.brohammad.tech
# Copy to .env.prod on your VPS and replace ALL REPLACE_* values before going live.
#
# Security: APP_ENV=production enables validate_security() fail-fast.
# Default credentials (alphaedge:alphaedge) will refuse to start.

APP_ENV=production
APP_DEBUG=false
TRUST_PROXY_HEADERS=true

# REQUIRED — generate on the server:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=REPLACE_ME
JWT_SECRET_KEY=REPLACE_ME

# REQUIRED — strong Postgres password (must match POSTGRES_PASSWORD below).
#   python3 -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://alphaedge:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/alphaedge

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

LLM_PROVIDER=mock
RESEARCH_PROVIDER=mock
QUOTE_PROVIDER=auto
RATE_LIMIT_ENABLED=true
LIVE_TRADING_ENABLED=false
CPP_ENGINE=auto

CORS_ORIGINS=["https://alphaedge.brohammad.tech"]

RUN_DEMO_SEED=true
REQUIRE_CELERY_READY=true
