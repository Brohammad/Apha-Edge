# Production public demo at https://alphaedge.brohammad.tech
# Copy to .env.prod on your VPS and replace secrets before going live.

APP_ENV=development
APP_DEBUG=false
TRUST_PROXY_HEADERS=true

# REQUIRED — generate on the server:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=REPLACE_ME
JWT_SECRET_KEY=REPLACE_ME

DATABASE_URL=postgresql+asyncpg://alphaedge:alphaedge@postgres:5432/alphaedge
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

LLM_PROVIDER=mock
RESEARCH_PROVIDER=mock
QUOTE_PROVIDER=auto
RATE_LIMIT_ENABLED=true
LIVE_TRADING_ENABLED=false
CPP_ENGINE=auto

CORS_ORIGINS=["https://alphaedge.brohammad.tech"]

RUN_DEMO_SEED=true
