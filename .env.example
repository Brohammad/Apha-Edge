# ─────────────────────────────────────────────────────────────────────────────
# AlphaEdge — Environment variables
#
# Copy this file to `.env` and fill in the values.
#   cp .env.example .env
#
# Lines marked [REQUIRED IN PROD] must be set before deploying to production.
# Lines marked [OPTIONAL] can be left empty for local development.
# Lines with default values work out-of-the-box for the Docker Compose stack.
#
# Run `python scripts/validate_env.py` to verify your .env before starting.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
# APP_ENV: development | production | test
APP_ENV=development
APP_DEBUG=true
# [REQUIRED IN PROD] Generate with: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=change-me-in-production-use-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg driver is required (postgresql+asyncpg://...)
# For Docker Compose: host is "postgres"; for local: typically "localhost"
DATABASE_URL=postgresql+asyncpg://alphaedge:alphaedge@localhost:5432/alphaedge

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for: rate limiting, session cache, OAuth state tokens
REDIS_URL=redis://localhost:6379/0

# ── Celery ────────────────────────────────────────────────────────────────────
# Broker and result backend use separate Redis DBs to avoid key collisions
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── JWT ───────────────────────────────────────────────────────────────────────
# [REQUIRED IN PROD] Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ALGORITHM=HS256
# Access tokens expire quickly; refresh tokens are rotated on each use
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Production security ───────────────────────────────────────────────────────
# [REQUIRED IN PROD] Fernet key for encrypting broker credentials at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_ENCRYPTION_KEY=
# [OPTIONAL] If set, the /api/v1/metrics endpoint requires X-Metrics-Key: <value>
# Leave empty to allow admin-JWT-authenticated access only (recommended in prod)
METRICS_API_KEY=
# Set to true if the API sits behind a trusted reverse proxy (nginx/ALB)
# that sets X-Forwarded-For headers for rate limiting
TRUST_PROXY_HEADERS=false

# ── Live trading ──────────────────────────────────────────────────────────────
# [OPTIONAL] Enable live (real-money) order routing via Alpaca.
# Keep false until you have completed the production checklist.
LIVE_TRADING_ENABLED=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON array of allowed origins. Update for your production frontend domain.
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── OAuth (Google / GitHub) ───────────────────────────────────────────────────
# Register these exact callback URLs in each provider's developer console:
#   Google:  {OAUTH_REDIRECT_BASE_URL}/google/callback
#   GitHub:  {OAUTH_REDIRECT_BASE_URL}/github/callback
# Default for local dev: http://localhost:8000/api/v1/auth/oauth/{google|github}/callback
#
# IMPORTANT: Do NOT put the frontend URL in Google/GitHub — it is only the
# final post-login redirect target after the backend finishes the OAuth exchange.
# [OPTIONAL] Leave empty to disable Google / GitHub login
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8000/api/v1/auth/oauth
OAUTH_FRONTEND_CALLBACK_URL=http://localhost:5173/oauth/callback

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Market data ───────────────────────────────────────────────────────────────
# QUOTE_PROVIDER: auto | polygon | alpha_vantage | mock
# "auto" tries Polygon first, falls back to Alpha Vantage, then mock.
# Set to "mock" for fully offline development / CI.
QUOTE_PROVIDER=auto
# [OPTIONAL] Polygon.io API key — free tier returns previous-day close prices
POLYGON_API_KEY=
# [OPTIONAL] Alpha Vantage API key — fallback quote provider
ALPHA_VANTAGE_API_KEY=

# ── AI Insights ───────────────────────────────────────────────────────────────
# LLM_PROVIDER: openai | mock
# Set to "mock" for offline CI or when you don't have an OpenAI key.
LLM_PROVIDER=openai
# [OPTIONAL] Required when LLM_PROVIDER=openai
OPENAI_API_KEY=
# Model to use for strategy insights and explanations
OPENAI_MODEL=gpt-4o-mini

# ── Indian brokers (Zerodha Kite Connect) ─────────────────────────────────────
# [OPTIONAL] OAuth app credentials from https://developers.kite.trade
ZERODHA_API_KEY=
ZERODHA_API_SECRET=

# ── Indian brokers (Angel One SmartAPI) ───────────────────────────────────────
ANGELONE_API_KEY=

# ── Indian brokers (Upstox) ───────────────────────────────────────────────────
UPSTOX_API_KEY=
UPSTOX_API_SECRET=

# ── Indian market data ────────────────────────────────────────────────────────
# INDIAN_MARKET_DATA_PROVIDER: mock | indian
INDIAN_MARKET_DATA_PROVIDER=mock

# ── Tavily research ───────────────────────────────────────────────────────────
RESEARCH_PROVIDER=mock
TAVILY_API_KEY=

# ── SEC EDGAR ─────────────────────────────────────────────────────────────────
SEC_USER_AGENT=AlphaEdge research@example.com

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_ENABLED=false

# ── Crypto brokers ────────────────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Set to false to disable rate limiting (useful for e2e tests)
# RATE_LIMIT_ENABLED=true
