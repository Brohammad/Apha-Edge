# Application
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production-use-a-long-random-string

# Database
DATABASE_URL=postgresql+asyncpg://alphaedge:alphaedge@localhost:5432/alphaedge

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Production security (required when APP_ENV=production)
CREDENTIALS_ENCRYPTION_KEY=
METRICS_API_KEY=
TRUST_PROXY_HEADERS=false

# Live trading
LIVE_TRADING_ENABLED=false

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# OAuth — register these exact callback URLs in each provider console:
#   Google:  {OAUTH_REDIRECT_BASE_URL}/google/callback
#   GitHub:  {OAUTH_REDIRECT_BASE_URL}/github/callback
# Default (local): http://localhost:8000/api/v1/auth/oauth/{google|github}/callback
# Do NOT use the frontend URL (/oauth/callback) in Google/GitHub — that is only the
# post-login redirect target after the backend finishes the OAuth exchange.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8000/api/v1/auth/oauth
OAUTH_FRONTEND_CALLBACK_URL=http://localhost:5173/oauth/callback

# Logging
LOG_LEVEL=INFO

# Market Data (optional — mock provider works without keys)
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=

# AI Insights (mock works offline; set openai for real LLM reports)
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
